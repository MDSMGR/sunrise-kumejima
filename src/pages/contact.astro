---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
import { courses as courseList } from '../data/courses';
import PageHero from '../components/PageHero.astro';
import { heroPool } from '../data/media';
---

<Base title="お問い合わせ" description="久米島ツアーSUNRISEへのお問い合わせ・ご予約相談はこちら。ご希望の日程・プラン・人数をお送りください。">
  <PageHero eyebrow="Contact" title="お問い合わせ" watermark="縁" pool={heroPool} image="/images/courses/course-hatenohama.webp" alt="久米島の海" />
  <section class="pt-16">
    <div class="wrap max-w-3xl">
      <p class="text-[15px] leading-loose text-inksoft">ご希望の日程・プラン・人数をお送りください。<br class="hidden sm:block">折り返し、空き状況と詳細をご案内します。<br class="hidden sm:block">お急ぎの場合は LINE が便利です。</p>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap grid gap-12 lg:grid-cols-[1fr_360px]">
      <!-- form -->
      <div>
        <form
          name="contact"
          method="POST"
          action="/thanks"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>このフィールドは入力しないでください<input name="bot-field" /></label>
          </p>

          <div class="grid gap-6 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-semibold text-ink">お名前 <span class="text-sun">*</span></span>
              <input type="text" name="name" required autocomplete="name"
                class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-sun" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-ink">メールアドレス <span class="text-sun">*</span></span>
              <input type="email" name="email" required autocomplete="email"
                class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-sun" />
            </label>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-semibold text-ink">電話番号</span>
              <input type="tel" name="tel" autocomplete="tel"
                class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-sun" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-ink">ご希望のコース</span>
              <select name="course"
                class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-sun">
                <option value="">選択してください</option>
                {courseList.map((c) => <option value={c.name}>{c.name}</option>)}
                <option value="未定・相談したい">未定・相談したい</option>
              </select>
            </label>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-semibold text-ink">ご希望日</span>
              <input type="date" name="date"
                class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-sun" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-ink">参加人数</span>
              <input type="number" name="people" min="1" inputmode="numeric"
                class="mt-2 w-full rounded-xl border border-ink/15 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-sun" />
            </label>
          </div>

          <label class="block">
            <span class="text-sm font-semibold text-ink">お問い合わせ内容 <span class="text-sun">*</span></span>
            <textarea name="message" rows="5" required
              class="mt-2 w-full resize-y rounded-xl border border-ink/15 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-sun"
              placeholder="ご質問・ご要望をご記入ください。"></textarea>
          </label>

          <label class="flex items-start gap-3 text-sm text-ink/75">
            <input type="checkbox" name="agree" required class="mt-1 h-4 w-4 accent-sun" />
            <span><a href="/legal/privacy" class="text-ember underline">プライバシーポリシー</a>に同意します。</span>
          </label>

          <button type="submit" class="btn-primary w-full sm:w-auto">送信する</button>
        </form>
      </div>

      <!-- aside -->
      <aside class="space-y-6">
        <div class="rounded-3xl bg-white p-7 shadow-soft">
          <p class="eyebrow">QUICK CONTACT</p>
          <p class="mt-3 text-sm text-ink/70">LINEなら、日程調整もスムーズです。</p>
          <a href={site.line} target="_blank" rel="noopener" class="btn-line mt-5 w-full">LINEで予約・相談</a>
        </div>
        <div class="rounded-3xl bg-white p-7 shadow-soft">
          <p class="eyebrow">SHOP INFO</p>
          <dl class="mt-4 space-y-3 text-sm text-ink/75">
            <div>
              <dt class="font-semibold text-ink">住所</dt>
              <dd class="mt-1">{site.address}</dd>
            </div>
            <div>
              <dt class="font-semibold text-ink">電話</dt>
              <dd class="mt-1"><a href={`tel:${site.tel}`} class="text-ember hover:underline">{site.tel}</a></dd>
            </div>
            <div>
              <dt class="font-semibold text-ink">メール</dt>
              <dd class="mt-1 break-all"><a href={`mailto:${site.email}`} class="text-ember hover:underline">{site.email}</a></dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </section>
</Base>
