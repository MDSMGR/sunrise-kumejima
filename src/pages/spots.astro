---
import Base from '../layouts/Base.astro';
import { sentences } from '../lib/text';
import { spots } from '../data/site';
import PageHero from '../components/PageHero.astro';

const sup = spots.filter((s) => s.kind === 'SUP');
const snorkel = spots.filter((s) => s.kind === 'シュノーケル');
---

<Base title="スポット紹介" description="久米島のSUP・シュノーケルスポットをSUNRISEがご紹介。はての浜、イーフビーチ、畳石エリアなど、久米島の海の魅力スポット。">
  <PageHero eyebrow="Spots" title="スポット紹介" watermark="海" image="/images/courses/course-hatenohama.jpg" alt="はての浜の白い砂浜と海" />
  <section class="pt-16">
    <div class="wrap max-w-3xl">
      <p class="text-[15px] leading-loose text-inksoft">久米島には、思わず息をのむ海がいくつもあります。<br>SUP・シュノーケルそれぞれのおすすめスポットをご紹介します。</p>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap space-y-16">
      <div data-reveal>
        <p class="eyebrow"><span class="h-px w-6 bg-sun"></span>SUP SPOTS</p>
        <h2 class="mt-3 font-mincho text-2xl font-normal text-ink sm:text-3xl">SUPで漕ぎ出す海</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {sup.map((s) => (
            <div class="rounded-3xl bg-white p-7 shadow-soft">
              <h3 class="font-mincho text-xl font-normal text-ember">{s.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink/70" set:html={sentences(s.body)}></p>
            </div>
          ))}
        </div>
      </div>

      <div data-reveal>
        <p class="eyebrow"><span class="h-px w-6 bg-sun"></span>SNORKEL SPOTS</p>
        <h2 class="mt-3 font-mincho text-2xl font-normal text-ink sm:text-3xl">水の中で出会う海</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {snorkel.map((s) => (
            <div class="rounded-3xl bg-white p-7 shadow-soft">
              <h3 class="font-mincho text-xl font-normal text-ember">{s.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink/70" set:html={sentences(s.body)}></p>
            </div>
          ))}
        </div>
      </div>

      <p class="text-xs text-ink/50">
        ※ 当日のコンディションにより、ご案内するスポットは変わる場合があります。安全とベストな景色を優先してガイドが判断します。
      </p>
    </div>
  </section>
</Base>
