---
import Base from '../layouts/Base.astro';
import { faqs, site } from '../data/site';
---

<Base title="よくある質問" description="SUNRISE 久米島によくいただくご質問にお答えします。参加条件・持ち物・予約方法・雨天時の対応など。">
  <section class="relative overflow-hidden pb-16 pt-32 text-sand"
           style="background: linear-gradient(135deg, #0e7c86, #06303a);">
    <div class="wrap">
      <p class="eyebrow !text-gold">FAQ</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold sm:text-5xl">よくある質問</h1>
      <p class="mt-4 max-w-xl text-sand/75">
        はじめての方からよくいただくご質問をまとめました。ここにない疑問は、LINEでお気軽に。
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap max-w-3xl">
      <div class="divide-y divide-abyss/10 overflow-hidden rounded-3xl bg-white shadow-card">
        {faqs.map((faq) => (
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-6 font-display font-bold text-abyss transition-colors hover:text-dawn">
              <span class="flex items-start gap-3">
                <span class="font-display text-dawn">Q.</span>
                {faq.q}
              </span>
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-sand text-lagoon transition-transform group-open:rotate-45">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="6" x2="12" y2="18"/><line x1="6" y1="12" x2="18" y2="12"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-[15px] leading-loose text-abyss/75">
              {faq.a}
            </div>
          </details>
        ))}
      </div>

      <div class="mt-10 rounded-3xl bg-abyss p-8 text-center text-sand">
        <p class="font-display text-xl font-extrabold">解決しませんでしたか？</p>
        <p class="mt-2 text-sm text-sand/70">どんな小さなことでも、お気軽にご相談ください。</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href={site.line} target="_blank" rel="noopener" class="btn-line">LINEで質問する</a>
          <a href="/contact" class="btn border border-white/40 text-white hover:bg-white/10">フォームで問い合わせ</a>
        </div>
      </div>
    </div>
  </section>
</Base>
