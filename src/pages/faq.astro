---
import Base from '../layouts/Base.astro';
import { sentences } from '../lib/text';
import { faqs, site } from '../data/site';
import PageHero from '../components/PageHero.astro';
---

<Base title="よくある質問" description="久米島ツアーSUNRISEによくいただくご質問にお答えします。参加条件・持ち物・予約方法・雨天時の対応など。">
  <PageHero eyebrow="FAQ" title="よくある質問" watermark="問" image="/images/courses/course-snorkel.webp" alt="久米島のシュノーケルの様子" />
  <section class="pt-16">
    <div class="wrap max-w-3xl">
      <p class="text-[15px] leading-loose text-inksoft">はじめての方からよくいただくご質問をまとめました。<br>ここにない疑問は、LINEでお気軽に。</p>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap max-w-3xl">
      <div class="divide-y divide-ink/10 overflow-hidden rounded-3xl bg-white shadow-soft">
        {faqs.map((faq) => (
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-6 font-mincho font-bold text-ink transition-colors hover:text-sun">
              <span class="flex items-start gap-3">
                <span class="font-mincho text-sun">Q.</span>
                {faq.q}
              </span>
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-paper text-ember transition-transform group-open:rotate-45">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="6" x2="12" y2="18"/><line x1="6" y1="12" x2="18" y2="12"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-[15px] leading-loose text-ink/75">
              <span set:html={sentences(faq.a)}></span>
            </div>
          </details>
        ))}
      </div>

      <div class="mt-10 rounded-3xl bg-ink p-8 text-center text-paper">
        <p class="font-mincho text-xl font-normal">解決しませんでしたか？</p>
        <p class="mt-2 text-sm text-paper/70">どんな小さなことでも、お気軽にご相談ください。</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href={site.line} target="_blank" rel="noopener" class="btn-line">LINEで質問する</a>
          <a href="/contact" class="btn border border-white/40 text-white hover:bg-white/10">フォームで問い合わせ</a>
        </div>
      </div>
    </div>
  </section>
</Base>
