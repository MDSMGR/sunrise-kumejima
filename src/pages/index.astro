---
import Base from '../layouts/Base.astro';
import { sentences } from '../lib/text';
import SectionHeading from '../components/SectionHeading.astro';
import SunDivider from '../components/SunDivider.astro';
import CourseCard from '../components/CourseCard.astro';
import GroupCard from '../components/GroupCard.astro';
import { topLevel, options } from '../data/courses';
import { site } from '../data/site';

const gallery = [
  '/images/courses/course-sup.jpg',
  '/images/courses/course-hatenohama.jpg',
  '/images/courses/course-snorkel.jpg',
  '/images/courses/course-fishing.jpg',
  '/images/hero-sup.jpg',
  '/images/courses/course-trekking.jpg',
  '/images/courses/course-stargazing.jpg',
  '/images/gallery-view.jpg',
];
---
<Base>
  <!-- HERO : full-bleed -->
  <section class="fullbleed relative flex min-h-[100svh] items-center overflow-hidden text-white">
    <img src="/images/hero-sup.jpg" alt="久米島の夕陽の海でSUPを楽しむ様子" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0" style="background:linear-gradient(180deg,rgba(34,22,12,.34) 0%,rgba(34,22,12,.18) 45%,rgba(47,36,25,.66) 100%)"></div>

    <div class="relative z-10 mx-auto w-full max-w-content px-6 pb-16 pt-32 sm:px-8">
      <p class="flex items-center gap-3 animate-rise">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-mincho text-[13px] tracking-[0.18em] text-gold sm:text-base" style="text-shadow:0 1px 8px rgba(34,22,12,.55)">Okinawa, Kumejima</span>
      </p>
      <h1 class="mt-4 h-hero text-[34px] leading-[1.32] text-white sm:text-[64px] sm:leading-[1.3] animate-rise" style="animation-delay:.08s">
        あなたは、本当の海を<br>知っていますか？
      </h1>
      <p class="mt-6 max-w-xl text-[15.5px] leading-loose text-white/90 animate-rise" style="animation-delay:.16s">
        透明度も、夕陽も、静けさも。<br>久米島の海には、まだ知らないあなたの海があります。
      </p>
      <div class="mt-9 flex flex-wrap gap-3 animate-rise" style="animation-delay:.24s">
        <a href={site.line} target="_blank" rel="noopener" class="btn-line">LINEで予約・相談</a>
        <a href="/courses" class="btn border border-white/50 bg-white/10 text-white backdrop-blur hover:bg-white/20">プランを見る</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="relative overflow-hidden py-24">
    <span class="watermark left-0 top-8 text-[34vw] sm:text-[260px]">海</span>
    <div class="relative wrap grid items-center gap-14 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="About us" title="私たち SUNRISE について" />
        <div class="mt-6 space-y-4 text-[15px] leading-loose text-inksoft">
          <p>私たち SUNRISE は、沖縄・久米島でマリンアクティビティをご案内する体験ショップです。<br>SUP・シュノーケルから、はての浜ツアー、釣り、トレッキングまで。<br>久米島の海と自然を、さまざまな角度からご案内します。</p>
          <p>島を知り尽くしたガイドが、あなたの「本当の久米島」との出会いを、安全第一でお手伝いします。<br>（※会社紹介文は仮です。正式な文面に差し替えてください）</p>
        </div>
      </div>
      <div class="hidden overflow-hidden rounded-3xl border border-line shadow-soft lg:block">
        <img src="/images/courses/course-hatenohama.jpg" alt="はての浜の白い砂浜と海" class="aspect-[4/3] w-full object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- COURSES -->
  <section class="relative overflow-hidden py-12">
    <span class="watermark right-0 top-4 text-[30vw] sm:text-[220px]">遊</span>
    <div class="relative wrap">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionHeading eyebrow="Choose your plan" title="あなたのプランを選ぶ" />
        <a href="/courses" class="font-fraunces italic text-sun hover:underline">すべて見る →</a>
      </div>
      <div class="mt-12 grid items-start gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {topLevel.map((item) => (item.kind === 'group'
          ? <GroupCard group={item.group} count={item.group.members.length} />
          : <CourseCard course={item.course} />))}
      </div>
    </div>
  </section>

  <!-- GALLERY strip : full-bleed -->
  <section class="py-20">
    <div class="wrap"><SectionHeading eyebrow="Gallery" title="久米島の、最高の一日" align="center" /></div>
    <div class="fullbleed mt-12 grid grid-cols-2 sm:grid-cols-4">
      {gallery.map((src) => (
        <div class="aspect-square overflow-hidden">
          <img src={src} alt="久米島での体験の様子" class="h-full w-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- OPTIONS -->
  <section class="py-20">
    <div class="wrap">
      <SectionHeading eyebrow="Options" title="思い出を、もっと鮮やかに残す" align="center" />
      <p class="mx-auto mt-4 max-w-xl text-center text-[15px] leading-loose text-inksoft">
        ツアーをさらに特別な思い出に。<br>体験を鮮やかに彩る追加オプションをご用意しています。
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {options.map((opt, i) => (
          <div class="rounded-2xl border border-line bg-card p-7">
            <span class="font-fraunces italic text-4xl text-gold">0{i + 1}</span>
            <h3 class="mt-2 font-mincho text-lg text-ink">{opt.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-inksoft" set:html={sentences(opt.body)}></p>
            {opt.note && <p class="mt-3 text-xs text-ember">{opt.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAFE TEASER : full-bleed split -->
  <section class="fullbleed grid md:grid-cols-2">
    <div class="relative min-h-[320px]">
      <img src="/images/cafe-interior.jpg" alt="Cafe & Bar SUNRISE の店内" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
    </div>
    <div class="relative flex items-center overflow-hidden bg-ink px-8 py-16 text-paper sm:px-14">
      <span class="watermark watermark-light right-6 top-6 text-[120px]">食</span>
      <div class="relative">
        <p class="font-fraunces italic text-gold text-lg">Sister shop</p>
        <h2 class="mt-3 h-display text-3xl text-paper sm:text-4xl">Cafe &amp; Bar SUNRISE</h2>
        <p class="mt-5 text-[15px] leading-loose text-paper/80">
          海あそびの余韻を、もう一杯。<br>タコライスや紅芋ブリュレ、車海老の塩焼きなど、<br>島の味をテラスでゆっくり楽しめます。
        </p>
        <a href="/cafe" class="btn-primary mt-7">Cafe &amp; Bar を見る</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="wrap pt-20">
    <div class="relative overflow-hidden rounded-[2rem] px-8 py-16 text-center sm:px-16" style="background:linear-gradient(135deg,#E8821C 0%,#F3B83A 100%)">
      <div class="absolute inset-0 opacity-20" aria-hidden="true" style="background-image:radial-gradient(circle at 20% 20%,#fff 0,transparent 40%),radial-gradient(circle at 80% 70%,#fff 0,transparent 35%)"></div>
      <div class="relative">
        <h2 class="h-display text-3xl text-white sm:text-4xl">久米島の海で、待っています</h2>
        <p class="mx-auto mt-4 max-w-md text-white/90">ご予約・ご相談は LINE またはお問い合わせフォームから。<br>空き状況をすぐにご案内します。</p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href={site.line} target="_blank" rel="noopener" class="btn bg-white text-sun shadow-lift hover:-translate-y-0.5">LINEで予約・相談</a>
          <a href="/contact" class="btn border border-white/60 text-white hover:bg-white/10">フォームで問い合わせ</a>
        </div>
      </div>
    </div>
  </section>
</Base>
