---
import Base from '../../layouts/Base.astro';
import CourseGallery from '../../components/CourseGallery.astro';
import CourseCard from '../../components/CourseCard.astro';
import { courses, groups, priceNote, facilityInfo } from '../../data/courses';
import { site } from '../../data/site';
import { sentences } from '../../lib/text';

export function getStaticPaths() {
  const groupPaths = groups.map((group) => ({
    params: { slug: group.slug },
    props: {
      kind: 'group',
      group,
      members: group.members.map((s) => courses.find((c) => c.slug === s)),
    },
  }));
  const coursePaths = courses.map((course, i) => ({
    params: { slug: course.slug },
    props: {
      kind: 'course',
      course,
      prev: courses[(i - 1 + courses.length) % courses.length],
      next: courses[(i + 1) % courses.length],
    },
  }));
  return [...groupPaths, ...coursePaths];
}

const { kind } = Astro.props as any;
---
{kind === 'group' ? (
  (() => {
    const { group, members } = Astro.props as any;
    return (
      <Base title={group.name} description={group.summary}>
        {/* 見出し（写真の上に載せず、左上に大きく） */}
        <section class="wrap pt-28 pb-6 sm:pt-32 sm:pb-8">
          <p class="font-fraunces italic text-ember text-base sm:text-lg">{group.tag}</p>
          <h1 class="mt-1 h-hero text-[28px] leading-tight text-ink sm:text-[46px]">{group.name}</h1>
          <p class="mt-3 max-w-2xl text-[15px] leading-loose text-inksoft">{group.summary}<br class="hidden sm:block">気になるプランをタップすると、写真と詳しい内容がご覧いただけます。</p>
        </section>

        {/* 1枚のヒーロー写真（テキストなし） */}
        <div class="fullbleed relative overflow-hidden">
          <img src={group.image} alt={group.name} class="h-[38vh] w-full object-cover sm:h-[52vh]" style={group.imagePos ? `object-position:${group.imagePos}` : undefined} />
        </div>

        <section class="py-12 sm:py-14">
          <div class="wrap grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {members.map((course: any) => <CourseCard course={course} />)}
          </div>
        </section>

        <section class="wrap pb-20">
          <a href="/courses" class="font-fraunces italic text-sun hover:underline">← すべてのメニュー</a>
        </section>
      </Base>
    );
  })()
) : (
  (() => {
    const { course, prev, next } = Astro.props as any;
    const heroImg = course.image ?? (course.gallery && course.gallery[0]);
    return (
      <Base title={course.name} description={course.summary}>
        {/* ① ツアー名（左上に大きく・写真の上に載せない） */}
        <section class="wrap pt-28 pb-6 sm:pt-32 sm:pb-8">
          <p class="font-fraunces italic text-ember text-base sm:text-lg">{course.tag}</p>
          <h1 class="mt-1 h-hero text-[28px] leading-tight text-ink sm:text-[46px]">{course.name}</h1>
          <p class="mt-3 font-mincho text-lg text-ember sm:text-xl">{course.tagline}</p>
        </section>

        {/* ② 1枚のヒーロー写真（テキストなし） */}
        {heroImg && (
          <div class="fullbleed relative overflow-hidden">
            <img src={heroImg} alt={`${course.name}の様子`} class="h-[42vh] w-full object-cover sm:h-[58vh]" />
          </div>
        )}

        {/* ③ じゃらん風の詳細（時間・料金）＋ ④ 予約ボタン（LINE＋電話） */}
        <section class="py-10 sm:py-14">
          <div class="wrap max-w-3xl">
            {(course.price || course.duration) && (
              <dl class="flex flex-wrap gap-x-10 gap-y-3 rounded-2xl border border-line bg-card px-6 py-5">
                {course.duration && (
                  <div>
                    <dt class="font-fraunces italic text-ember text-xs">所要時間</dt>
                    <dd class="mt-0.5 font-mincho text-lg tracking-wide2 text-ink">{course.duration}</dd>
                  </div>
                )}
                {course.price && (
                  <div>
                    <dt class="font-fraunces italic text-ember text-xs">料金</dt>
                    <dd class="mt-0.5 font-mincho text-lg tracking-wide2 text-ink">{course.price}</dd>
                  </div>
                )}
              </dl>
            )}
            {course.price && <p class="mt-2 text-xs leading-relaxed text-inksoft">{priceNote}</p>}

            <p class="mt-6 text-[15px] leading-loose text-inksoft" set:html={sentences(course.detail)}></p>

            <div class="mt-6 flex flex-wrap gap-2">
              {course.highlights.map((h: string) => (
                <span class="rounded-full border border-line bg-card px-3.5 py-1.5 text-xs font-medium text-ember">{h}</span>
              ))}
            </div>

            {/* 予約ボタン：LINEの隣に電話 */}
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a href={site.line} target="_blank" rel="noopener" class="btn-line flex-1 justify-center">LINEで予約・相談</a>
              <a href={`tel:${site.tel}`} class="btn-primary flex-1 justify-center">電話で予約する</a>
            </div>
          </div>
        </section>

        {/* ⑤ ギャラリー写真 */}
        <section class="pb-4 sm:pb-8">
          <div class="wrap max-w-4xl">
            <CourseGallery images={course.gallery ?? [course.image]} alt={`${course.name}の様子`} />
          </div>
        </section>

        {/* ⑥ 集合場所等の事務的な記述 */}
        <section class="py-10 sm:py-14">
          <div class="wrap max-w-3xl">
            <h2 class="font-mincho text-xl tracking-wide2 text-ink">ご利用案内</h2>
            <dl class="mt-4 grid gap-x-8 gap-y-3 border-t border-line pt-6 sm:grid-cols-2">
              {facilityInfo.map((it) => (
                <div>
                  <dt class="font-fraunces italic text-ember text-xs">{it.label}</dt>
                  <dd class="mt-0.5 text-[13.5px] leading-relaxed text-inksoft">{it.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </section>

        {/* 前後ナビ */}
        <section class="wrap pb-20">
          <div class="flex flex-col gap-4 border-t border-line pt-8 text-sm sm:flex-row sm:items-center sm:justify-between">
            <a href={`/courses/${prev.slug}`} class="flex items-center gap-2 text-inksoft transition-colors hover:text-sun"><span>←</span><span class="font-mincho">{prev.name}</span></a>
            <a href="/courses" class="font-fraunces italic text-sun hover:underline">All menu</a>
            <a href={`/courses/${next.slug}`} class="flex items-center gap-2 text-inksoft transition-colors hover:text-sun"><span class="font-mincho">{next.name}</span><span>→</span></a>
          </div>
        </section>
      </Base>
    );
  })()
)}
