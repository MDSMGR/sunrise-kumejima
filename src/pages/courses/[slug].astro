---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import CourseGallery from '../../components/CourseGallery.astro';
import CourseCard from '../../components/CourseCard.astro';
import SunDivider from '../../components/SunDivider.astro';
import { courses, groups, options } from '../../data/courses';
import { site } from '../../data/site';
import { sentences } from '../../lib/text';

export function getStaticPaths() {
  const wm: Record<string, string> = { sup: '海', hama: '浜', trekking: '森', yugyosen: '釣' };
  const groupPaths = groups.map((group) => ({
    params: { slug: group.slug },
    props: {
      kind: 'group',
      group,
      members: group.members.map((s) => courses.find((c) => c.slug === s)),
      wm: wm[group.slug] ?? '遊',
    },
  }));
  const cwm: Record<string, string> = {
    sup: '海', hama: '浜', trekking: '森', yugyosen: '釣',
  };
  const coursePaths = courses.map((course, i) => ({
    params: { slug: course.slug },
    props: {
      kind: 'course',
      course,
      prev: courses[(i - 1 + courses.length) % courses.length],
      next: courses[(i + 1) % courses.length],
      wm: cwm[course.group ?? ''] ?? '遊',
    },
  }));
  return [...groupPaths, ...coursePaths];
}

const { kind } = Astro.props as any;
---
{kind === 'group' ? (
  (() => {
    const { group, members, wm } = Astro.props as any;
    return (
      <Base title={group.name} description={group.summary}>
        <PageHero eyebrow={group.tag} title={group.name} watermark={wm} image={group.image} alt={group.name} />
        <section class="pt-16">
          <div class="wrap max-w-3xl">
            <p class="text-[15px] leading-loose text-inksoft">{group.summary}<br>気になるプランをタップすると、写真と詳しい内容がご覧いただけます。</p>
          </div>
        </section>
        <section class="py-14">
          <div class="wrap grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {members.map((course: any) => <CourseCard course={course} />)}
          </div>
        </section>
        <section class="wrap pb-20">
          <a href="/courses" class="font-fraunces italic text-sun hover:underline">← すべてのメニュー</a>
        </section>
      </Base>
    );
  })()
) : (
  (() => {
    const { course, prev, next, wm } = Astro.props as any;
    return (
      <Base title={course.name} description={course.summary}>
        <PageHero eyebrow={course.tag} title={course.name} watermark={wm} image={course.image} alt={`${course.name}の様子`} />
        <section class="py-16">
          <div class="wrap grid items-start gap-12 lg:grid-cols-[1.02fr_.98fr]">
            <div>
              <p class="font-mincho text-2xl tracking-[0.06em] text-ember sm:text-[28px]">{course.tagline}</p>
              <p class="mt-6 text-[15px] leading-loose text-inksoft" set:html={sentences(course.detail)}></p>
              <div class="mt-7 flex flex-wrap gap-2">
                {course.highlights.map((h: string) => (
                  <span class="rounded-full border border-line bg-card px-3.5 py-1.5 text-xs font-medium text-ember">{h}</span>
                ))}
              </div>
              <a href={site.line} target="_blank" rel="noopener" class="btn-line mt-9">このプランを予約・相談</a>
            </div>
            <div>
              <CourseGallery images={course.gallery ?? [course.image]} alt={`${course.name}の様子`} />
            </div>
          </div>
        </section>

        <div class="wrap"><SunDivider /></div>

        <section class="py-16">
          <div class="wrap">
            <h2 class="text-center font-mincho text-2xl text-ink sm:text-3xl">思い出を、もっと鮮やかに</h2>
            <p class="mx-auto mt-4 max-w-xl text-center text-[15px] leading-loose text-inksoft">体験を彩る追加オプションをご用意しています。<br>ツアー予約時にお気軽にご相談ください。</p>
            <div class="mt-10 grid gap-6 sm:grid-cols-2">
              {options.map((opt: any, i: number) => (
                <div class="rounded-2xl border border-line bg-card p-7">
                  <span class="font-fraunces italic text-3xl text-gold">0{i + 1}</span>
                  <h3 class="mt-2 font-mincho text-lg text-ink">{opt.name}</h3>
                  <p class="mt-3 text-sm leading-relaxed text-inksoft" set:html={sentences(opt.body)}></p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="wrap pb-20">
          <div class="flex flex-col gap-4 border-t border-line pt-8 text-sm sm:flex-row sm:items-center sm:justify-between">
            <a href={`/courses/${prev.slug}`} class="flex items-center gap-2 text-inksoft transition-colors hover:text-sun"><span>←</span><span class="font-mincho">{prev.name}</span></a>
            <a href="/courses" class="font-fraunces italic text-sun hover:underline">All menu</a>
            <a href={`/courses/${next.slug}`} class="flex items-center gap-2 text-inksoft transition-colors hover:text-sun"><span class="font-mincho">{next.name}</span><span>→</span></a>
          </div>
        </section>
      </Base>
    );
  })()
)}
