---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import SunDivider from '../../components/SunDivider.astro';
import { courses, options } from '../../data/courses';
import { site } from '../../data/site';
import { sentences } from '../../lib/text';

export function getStaticPaths() {
  return courses.map((course, i) => ({
    params: { slug: course.slug },
    props: {
      course,
      prev: courses[(i - 1 + courses.length) % courses.length],
      next: courses[(i + 1) % courses.length],
    },
  }));
}

const { course, prev, next } = Astro.props;
const wm: Record<string, string> = {
  sup: '海', snorkel: '海', hatenohama: '浜', fishing: '釣', trekking: '森', stargazing: '星',
};
---
<Base title={course.name} description={course.summary}>
  <PageHero eyebrow={course.tag} title={course.name} watermark={wm[course.slug] ?? '遊'} image={course.image} alt={`${course.name}の様子`} />

  <section class="py-16">
    <div class="wrap grid items-start gap-12 lg:grid-cols-[1.05fr_.95fr]">
      <div>
        <p class="font-mincho text-2xl tracking-[0.06em] text-ember sm:text-[28px]">{course.tagline}</p>
        <p class="mt-6 text-[15px] leading-loose text-inksoft" set:html={sentences(course.detail)}></p>
        <div class="mt-7 flex flex-wrap gap-2">
          {course.highlights.map((h) => (
            <span class="rounded-full border border-line bg-card px-3.5 py-1.5 text-xs font-medium text-ember">{h}</span>
          ))}
        </div>
        <a href={site.line} target="_blank" rel="noopener" class="btn-line mt-9">このコースを予約・相談</a>
      </div>
      <figure class="overflow-hidden rounded-3xl border border-line shadow-soft">
        <img src={course.image} alt={`${course.name}の様子`} class="aspect-[4/5] w-full object-cover" />
      </figure>
    </div>
  </section>

  <div class="wrap"><SunDivider /></div>

  <section class="py-16">
    <div class="wrap">
      <h2 class="text-center font-mincho text-2xl text-ink sm:text-3xl">思い出を、もっと鮮やかに</h2>
      <p class="mx-auto mt-4 max-w-xl text-center text-[15px] leading-loose text-inksoft">
        体験を彩る追加オプションをご用意しています。<br>ツアー予約時にお気軽にご相談ください。
      </p>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {options.map((opt, i) => (
          <div class="rounded-2xl border border-line bg-card p-7">
            <span class="font-fraunces italic text-3xl text-gold">0{i + 1}</span>
            <h3 class="mt-2 font-mincho text-lg text-ink">{opt.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-inksoft" set:html={sentences(opt.body)}></p>
            {opt.note && <p class="mt-3 text-xs text-ember">{opt.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="wrap pb-20">
    <div class="flex items-center justify-between gap-4 border-t border-line pt-8 text-sm">
      <a href={`/courses/${prev.slug}`} class="flex items-center gap-2 text-inksoft transition-colors hover:text-sun">
        <span>←</span><span class="font-mincho">{prev.name}</span>
      </a>
      <a href="/courses" class="font-fraunces italic text-sun hover:underline">All courses</a>
      <a href={`/courses/${next.slug}`} class="flex items-center gap-2 text-inksoft transition-colors hover:text-sun">
        <span class="font-mincho">{next.name}</span><span>→</span>
      </a>
    </div>
  </section>
</Base>
