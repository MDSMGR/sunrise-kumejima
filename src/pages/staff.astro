---
import Base from '../layouts/Base.astro';
import { staff, site } from '../data/site';
---

<Base title="スタッフ紹介" description="SUNRISE 久米島のガイド紹介。久米島の海を知り尽くしたガイドが、安全第一であなたの体験をご案内します。">
  <section class="bg-abyss pb-16 pt-32 text-sand">
    <div class="wrap">
      <p class="eyebrow !text-gold">STAFF</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold sm:text-5xl">スタッフ紹介</h1>
      <p class="mt-4 max-w-xl text-sand/75">
        あなたの久米島時間を、隣で一緒に楽しむ仲間たち。
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap grid gap-10">
      {staff.map((member) => (
        <article class="grid items-center gap-8 rounded-3xl bg-white p-6 shadow-card md:grid-cols-[260px_1fr] md:p-8" data-reveal>
          <div class="media aspect-square w-full">
            <div class="absolute inset-0 grid place-items-center text-white/80">
              <span class="text-xs uppercase tracking-[0.3em]">Photo</span>
            </div>
          </div>
          <div>
            <p class="eyebrow">{member.role}</p>
            <h2 class="mt-2 font-display text-2xl font-extrabold text-abyss">{member.name}</h2>
            <p class="mt-4 text-[15px] leading-loose text-abyss/75">{member.body}</p>
            <a href={site.line} target="_blank" rel="noopener" class="btn-line mt-6">LINEで相談する</a>
          </div>
        </article>
      ))}
      <p class="text-xs text-abyss/50">※ スタッフ写真・プロフィールは差し替え予定です。実際の顔写真や経歴を入れると、より信頼感が高まります。</p>
    </div>
  </section>
</Base>
