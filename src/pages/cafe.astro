---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SunDivider from '../components/SunDivider.astro';
import { cafe, site } from '../data/site';
import { cafeMenu, cafeMenuNote } from '../data/cafemenu';

const info = [
  { label: '営業時間', value: cafe.hours },
  { label: '定休日', value: cafe.closed },
  { label: 'テラス席', value: cafe.terrace ? 'あり' : 'なし' },
  { label: 'お支払い', value: cafe.payments.join(' ／ ') },
];
---
<Base title="Cafe & Bar SUNRISE" description="久米島のマリンショップ SUNRISE 系列店、Cafe & Bar SUNRISE。タコライス・紅芋ブリュレ・車海老の塩焼きなど島の味を、テラスでゆっくり。">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <img src="/images/cafe/interior.webp" alt="Cafe & Bar SUNRISE 店内" class="absolute inset-0 h-full w-full object-cover" fetchpriority="high" />
    <div class="absolute inset-0" style="background:linear-gradient(90deg,rgba(24,15,9,.78),rgba(24,15,9,.42) 70%,rgba(24,15,9,.28))"></div>
    <div class="wrap relative pt-32 pb-16 sm:pt-40 sm:pb-24">
      <div class="max-w-xl">
        <p class="font-fraunces italic text-[13px] tracking-wide text-white/85">Sister shop — Cafe &amp; Bar</p>
        <h1 class="mt-4 h-display text-white text-[38px] leading-[1.4] sm:text-[52px]">
          海の余韻を、<br class="hidden sm:block">もう一杯。
          <span class="mt-3 block font-fraunces italic font-normal text-gold text-[.52em]">Cafe &amp; Bar SUNRISE</span>
        </h1>
        <p class="mt-6 text-[15.5px] leading-loose text-white/90">
          ひと泳ぎした後の、ゆるやかな時間。<br class="hidden sm:block">島の食材を使ったフードと、夜は一杯のお酒を。<br class="hidden sm:block">テラスで潮風を感じながら、久米島の夜までゆっくりと。
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#menu" class="btn-primary">メニューを見る</a>
          <a href="/" class="inline-flex items-center rounded-full border border-white/70 px-6 py-3 text-sm text-white transition-colors hover:bg-white/10">マリンショップへ</a>
        </div>
      </div>
    </div>
  </section>

  <div class="wrap"><SunDivider /></div>

  <!-- INFO -->
  <section class="py-14">
    <div class="wrap">
      <SectionHeading eyebrow="Information" title="店舗情報" />
      <dl class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {info.map((it) => (
          <div class="rounded-2xl border border-line bg-card p-6">
            <dt class="font-fraunces italic text-ember text-sm">{it.label}</dt>
            <dd class="mt-2 font-mincho text-lg tracking-wide2 text-ink">{it.value}</dd>
          </div>
        ))}
      </dl>
      <p class="mt-6 text-xs text-inksoft">※ 営業時間・定休日は変更になる場合があります。<br class="hidden sm:block">最新情報は Instagram でご確認ください。</p>
    </div>
  </section>

  <!-- MENU -->
  <section id="menu" class="py-14 scroll-mt-24">
    <div class="wrap">
      <SectionHeading eyebrow="Menu" title="メニュー" align="center" />
      <p class="mx-auto mt-4 max-w-md text-center text-[14px] leading-relaxed text-inksoft">
        カテゴリを選んでご覧ください。
      </p>

      <!-- タブ -->
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        {cafeMenu.map((cat, i) => (
          <button type="button" data-cafe-tab={cat.id} aria-selected={i === 0 ? 'true' : 'false'}
            class="rounded-full border border-line px-4 py-2 text-sm font-medium text-inksoft transition-colors aria-selected:border-sun aria-selected:bg-sun aria-selected:text-white">
            {cat.label}
          </button>
        ))}
      </div>

      <!-- パネル -->
      <div class="mt-10">
        {cafeMenu.map((cat, i) => (
          <div data-cafe-panel={cat.id} hidden={i !== 0}>
            {cat.note && (
              <p class="mx-auto mb-6 max-w-xl text-center text-[13.5px] leading-relaxed text-ember">※ {cat.note}</p>
            )}
            <div class="grid items-start gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {cat.items.map((m) => (
                <article class="overflow-hidden rounded-2xl border border-line bg-card">
                  <div class={`flex aspect-square items-center justify-center overflow-hidden ${m.image ? 'bg-white' : 'bg-cream'}`}>
                    {m.image
                      ? <img src={m.image} alt={m.name} class="h-full w-full object-contain p-3" loading="lazy" />
                      : <svg class="h-10 w-10 text-gold/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19" stroke-linecap="round"/></svg>}
                  </div>
                  <div class="p-5">
                    <div class="flex items-baseline justify-between gap-3">
                      <h3 class="font-mincho text-lg tracking-wide2 text-ink">{m.name}</h3>
                      <span class="flex-none font-fraunces italic text-sun">{m.price}</span>
                    </div>
                    {m.en && <p class="mt-0.5 font-fraunces italic text-xs text-ember">{m.en}</p>}
                    {m.body && <p class="mt-2 text-[13px] leading-relaxed text-inksoft">{m.body}</p>}
                  </div>
                </article>
              ))}
            </div>

            {cat.extras && (
              <div class="mt-6 rounded-2xl border border-line bg-cream p-6">
                <p class="font-mincho text-base tracking-wide2 text-ink">{cat.extras.title}</p>
                <dl class="mt-3 grid gap-x-8 gap-y-2 sm:grid-cols-2">
                  {cat.extras.list.map((t) => (
                    <div class="flex items-baseline justify-between gap-3 border-b border-dashed border-line/70 pb-1">
                      <dt class="text-[13.5px] text-ink">{t.name}</dt>
                      <dd class="flex-none font-fraunces italic text-sm text-sun">{t.price}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
          </div>
        ))}
      </div>

      <p class="mx-auto mt-8 max-w-xl text-center text-xs text-inksoft">※ {cafeMenuNote}</p>
    </div>
  </section>

  <script>
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-cafe-tab]'));
    const panels = new Map(
      Array.from(document.querySelectorAll<HTMLElement>('[data-cafe-panel]'))
        .map((p) => [p.getAttribute('data-cafe-panel'), p] as const)
    );
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.getAttribute('data-cafe-tab');
        tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
        panels.forEach((panel, key) => { panel.hidden = key !== id; });
      });
    });
  </script>

  <!-- INSTAGRAM -->
  <section class="py-14">
    <div class="wrap">
      <div class="grid items-center gap-10 overflow-hidden rounded-3xl border border-line bg-cream p-8 sm:p-10 md:grid-cols-[1fr_1.4fr]">
        <div class="flex justify-center">
          <div class="rounded-2xl border border-line bg-card p-4">
            <img src="/images/cafe-instagram-qr.png" alt={`Instagram ${cafe.instagramHandle} のQRコード`} width="200" height="200" class="w-40 rounded-lg" loading="lazy" />
          </div>
        </div>
        <div>
          <p class="eyebrow">Instagram</p>
          <h2 class="mt-3 h-display text-2xl sm:text-3xl">最新情報はこちら</h2>
          <p class="mt-4 text-[15px] leading-loose text-inksoft">
            日々のメニューや営業のお知らせは Instagram で発信しています。<br class="hidden sm:block">スマホのカメラでQRコードを読み取ってフォローしてください。
          </p>
          <p class="mt-6 font-fraunces italic text-sun text-lg">{cafe.instagramHandle}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA back to marine -->
  <section class="wrap pt-10">
    <div class="relative overflow-hidden rounded-[2rem] px-8 py-14 text-center sm:px-16"
         style="background:linear-gradient(135deg,#E8821C 0%,#F3B83A 100%)">
      <div class="relative">
        <h2 class="font-mincho text-2xl tracking-wide2 text-white sm:text-3xl">海あそびと、島の食卓を一日で</h2>
        <p class="mx-auto mt-4 max-w-md text-white/90">昼はマリン体験、夜は Cafe &amp; Bar で乾杯。<br class="hidden sm:block">久米島を丸ごと楽しむプランもお気軽にご相談を。</p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a href="/courses" class="btn bg-white text-sun shadow-lift hover:-translate-y-0.5">コースを見る</a>
          <a href={site.line} target="_blank" rel="noopener" class="btn border border-white/60 text-white hover:bg-white/10">LINEで相談</a>
        </div>
      </div>
    </div>
  </section>
</Base>
