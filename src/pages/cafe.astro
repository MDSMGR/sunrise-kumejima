---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SunDivider from '../components/SunDivider.astro';
import { cafe, site } from '../data/site';

const info = [
  { label: '営業時間', value: cafe.hours },
  { label: '定休日', value: cafe.closed },
  { label: 'テラス席', value: cafe.terrace ? 'あり' : 'なし' },
  { label: 'お支払い', value: cafe.payments.join(' ／ ') },
];
---
<Base title="Cafe & Bar SUNRISE" description="久米島のマリンショップ SUNRISE 系列店、Cafe & Bar SUNRISE。タコライス・紅芋ブリュレ・車海老の塩焼きなど島の味を、テラスでゆっくり。">
  <!-- HERO -->
  <section class="relative overflow-hidden pt-28 pb-10 sm:pt-32">
    <div class="wrap grid items-center gap-12 lg:grid-cols-[1fr_.8fr]">
      <div>
        <p class="eyebrow">Sister shop — Cafe &amp; Bar</p>
        <h1 class="mt-4 h-display text-[38px] leading-[1.4] sm:text-[52px]">
          海の余韻を、<br>もう一杯。
          <span class="mt-3 block font-fraunces italic font-normal text-sun text-[.52em]">Cafe &amp; Bar SUNRISE</span>
        </h1>
        <p class="mt-6 max-w-xl text-[15.5px] leading-loose text-inksoft">
          ひと泳ぎした後の、ゆるやかな時間。<br>島の食材を使ったフードと、夜は一杯のお酒を。<br>テラスで潮風を感じながら、久米島の夜までゆっくりと。
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href={cafe.instagram} target="_blank" rel="noopener" class="btn-primary">Instagramを見る</a>
          <a href="/" class="btn-ghost">マリンショップへ</a>
        </div>
      </div>
      <div class="flex justify-center">
        <div class="rounded-3xl border border-line bg-card p-8 shadow-soft">
          <img src="/logo-cafe.png" alt="Cafe & Bar SUNRISE ロゴ" width="225" height="225" class="w-44 sm:w-52" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <div class="wrap"><SunDivider /></div>

  <!-- INFO -->
  <section class="py-14">
    <div class="wrap">
      <SectionHeading eyebrow="Information" title="店舗情報" />
      <dl class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {info.map((it) => (
          <div class="rounded-2xl border border-line bg-card p-6">
            <dt class="font-fraunces italic text-ember text-sm">{it.label}</dt>
            <dd class="mt-2 font-mincho text-lg tracking-wide2 text-ink">{it.value}</dd>
          </div>
        ))}
      </dl>
      <p class="mt-6 text-xs text-inksoft">※ 営業時間・定休日は変更になる場合があります。<br>最新情報は Instagram でご確認ください。</p>
    </div>
  </section>

  <!-- MENU -->
  <section class="py-14">
    <div class="wrap">
      <SectionHeading eyebrow="Signature menu" title="看板メニュー" align="center" />
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {cafe.menu.map((m) => (
          <article class="overflow-hidden rounded-2xl border border-line bg-card transition-all duration-300 hover:-translate-y-1 hover:shadow-soft">
            <div class="aspect-[4/3] overflow-hidden bg-cream">
              <img src={m.image} alt={m.name} class="h-full w-full object-cover" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-baseline justify-between gap-3">
                <h3 class="font-mincho text-xl tracking-wide2 text-ink">{m.name}</h3>
                <span class="font-fraunces italic text-sun text-lg">{m.price}</span>
              </div>
              <p class="mt-3 text-[14px] leading-relaxed text-inksoft">{m.body}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="mx-auto mt-8 max-w-xl text-center text-xs text-inksoft">
        ※ 価格は税込表示です。<br>メニューは季節により変わる場合があります。
      </p>
    </div>
  </section>

  <!-- INSTAGRAM -->
  <section class="py-14">
    <div class="wrap">
      <div class="grid items-center gap-10 overflow-hidden rounded-3xl border border-line bg-cream p-8 sm:p-10 md:grid-cols-[1fr_1.4fr]">
        <div class="flex justify-center">
          <a href={cafe.instagram} target="_blank" rel="noopener" class="rounded-2xl border border-line bg-card p-4">
            <img src="/images/cafe-instagram-qr.jpg" alt={`Instagram ${cafe.instagramHandle} のQRコード`} width="200" height="200" class="w-40 rounded-lg" loading="lazy" />
          </a>
        </div>
        <div>
          <p class="eyebrow">Instagram</p>
          <h2 class="mt-3 h-display text-2xl sm:text-3xl">最新情報はこちら</h2>
          <p class="mt-4 text-[15px] leading-loose text-inksoft">
            日々のメニューや営業のお知らせは Instagram で発信しています。<br>QRコード、または下のリンクからフォローしてください。
          </p>
          <a href={cafe.instagram} target="_blank" rel="noopener" class="mt-6 inline-flex font-fraunces italic text-sun text-lg hover:underline">{cafe.instagramHandle} →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA back to marine -->
  <section class="wrap pt-10">
    <div class="relative overflow-hidden rounded-[2rem] px-8 py-14 text-center sm:px-16"
         style="background:linear-gradient(135deg,#E8821C 0%,#F3B83A 100%)">
      <div class="relative">
        <h2 class="font-mincho text-2xl tracking-wide2 text-white sm:text-3xl">海あそびと、島の食卓を一日で</h2>
        <p class="mx-auto mt-4 max-w-md text-white/90">昼はマリン体験、夜は Cafe &amp; Bar で乾杯。<br>久米島を丸ごと楽しむプランもお気軽にご相談を。</p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a href="/courses" class="btn bg-white text-sun shadow-lift hover:-translate-y-0.5">コースを見る</a>
          <a href={site.line} target="_blank" rel="noopener" class="btn border border-white/60 text-white hover:bg-white/10">LINEで相談</a>
        </div>
      </div>
    </div>
  </section>
</Base>
