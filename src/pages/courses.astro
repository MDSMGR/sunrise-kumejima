---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { courses, options } from '../data/courses';
import { site } from '../data/site';

const toneStyles: Record<string, string> = {
  dawn: 'radial-gradient(120% 120% at 80% -10%, rgba(255,194,75,0.7), transparent 55%), linear-gradient(135deg, #ff7a45, #c2410c)',
  gold: 'radial-gradient(120% 120% at 80% -10%, rgba(255,255,255,0.5), transparent 50%), linear-gradient(135deg, #ffc24b, #f59e0b)',
  lagoon: 'radial-gradient(120% 120% at 80% -10%, rgba(255,194,75,0.5), transparent 55%), linear-gradient(135deg, #0e7c86, #06303a)',
  shallow: 'radial-gradient(120% 120% at 80% -10%, rgba(255,255,255,0.45), transparent 55%), linear-gradient(135deg, #5fc9c4, #0e7c86)',
  deep: 'radial-gradient(120% 120% at 80% 0%, rgba(95,201,196,0.45), transparent 55%), linear-gradient(135deg, #0e7c86, #041f26)',
};
---

<Base title="コースのご案内" description="SUNRISE 久米島のマリン体験コース一覧。体験SUP・シュノーケル・はての浜ツアー・フィッシング・トレッキング・星空ツアーをご案内します。">
  <!-- page hero -->
  <section class="bg-abyss pb-16 pt-32 text-sand">
    <div class="wrap">
      <p class="eyebrow !text-gold">COURSES</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold sm:text-5xl">コースのご案内</h1>
      <p class="mt-4 max-w-xl text-sand/75">
        久米島の海と自然を、いろいろな角度から楽しめる6つの体験プラン。
        気になるコースが見つかったら、お気軽にご相談ください。
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap space-y-16">
      {courses.map((course, i) => (
        <article id={course.slug} class="grid items-center gap-8 lg:grid-cols-2" data-reveal class:list={[i % 2 === 1 && 'lg:[&>div:first-child]:order-2']}>
          <div class="media aspect-[16/11] w-full" style={`background-image: ${toneStyles[course.duotone]}`}>
            <span class="absolute left-5 top-5 rounded-full bg-white/15 px-3 py-1 text-[11px] font-bold uppercase tracking-widest text-white backdrop-blur">{course.tag}</span>
            <p class="absolute bottom-5 left-5 right-5 font-display text-2xl font-extrabold text-white drop-shadow">{course.tagline}</p>
          </div>
          <div>
            <h2 class="font-display text-2xl font-extrabold text-abyss sm:text-3xl">{course.name}</h2>
            <p class="mt-4 text-[15px] leading-loose text-abyss/75">{course.detail}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {course.highlights.map((h) => (
                <span class="rounded-full bg-sand px-3.5 py-1.5 text-xs font-semibold text-lagoon">{h}</span>
              ))}
            </div>
            <a href={site.line} target="_blank" rel="noopener" class="btn-line mt-7">このコースを予約・相談</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- options -->
  <section class="bg-white py-20">
    <div class="wrap">
      <SectionHeading eyebrow="OPTIONS" title="追加オプション" />
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {options.map((opt) => (
          <div class="rounded-3xl border border-abyss/10 bg-sand p-7">
            <h3 class="font-display text-lg font-extrabold text-abyss">{opt.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-abyss/70">{opt.body}</p>
            {opt.note && <p class="mt-3 text-xs text-dawn">{opt.note}</p>}
          </div>
        ))}
      </div>
      <p class="mt-8 text-xs text-abyss/50">
        ※ 料金・所要時間・開催時期はシーズンや海況により変動します。詳細は予約時にご案内します。
      </p>
    </div>
  </section>
</Base>
