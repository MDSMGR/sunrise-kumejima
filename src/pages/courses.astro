---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageHero from '../components/PageHero.astro';
import CourseCard from '../components/CourseCard.astro';
import GroupCard from '../components/GroupCard.astro';
import { topLevel, options, priceNote } from '../data/courses';
import { sentences } from '../lib/text';
---
<Base title="コースのご案内" description="久米島ツアーSUNRISEのマリン体験コース一覧。体験SUP・シュノーケル・はての浜ツアー・フィッシング・トレッキング・星空ツアーをご案内します。">
  <PageHero eyebrow="Courses" title="コースのご案内" watermark="遊" image="/images/courses/course-sup.webp" alt="久米島でSUPを楽しむ様子" />
  <section class="pt-16">
    <div class="wrap max-w-3xl">
      <p class="text-[15px] leading-loose text-inksoft">久米島の海と自然を、いろいろな角度から楽しめる体験プラン。<br>気になるコースをタップすると、詳しい内容・料金・写真がご覧いただけます。</p>
      <p class="mt-3 text-xs leading-relaxed text-inksoft">{priceNote}</p>
    </div>
  </section>

  <section class="py-14">
    <div class="wrap grid items-start gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {topLevel.map((item) => (item.kind === 'group'
        ? <GroupCard group={item.group} count={item.group.members.length} />
        : <CourseCard course={item.course} />))}
    </div>
  </section>

  <!-- options -->
  <section class="bg-white py-20">
    <div class="wrap">
      <SectionHeading eyebrow="Options" title="追加オプション" align="center" />
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {options.map((opt, i) => (
          <div class="rounded-2xl border border-line bg-paper p-7">
            <span class="font-fraunces italic text-3xl text-gold">0{i + 1}</span>
            <h3 class="mt-2 font-mincho text-lg font-normal text-ink">{opt.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70" set:html={sentences(opt.body)}></p>
            {opt.note && <p class="mt-3 text-xs text-sun">{opt.note}</p>}
          </div>
        ))}
      </div>
      <p class="mt-8 text-xs text-ink/50">
        ※ 料金・所要時間・開催時期はシーズンや海況により変動します。<br>詳細は予約時にご案内します。
      </p>
    </div>
  </section>
</Base>
