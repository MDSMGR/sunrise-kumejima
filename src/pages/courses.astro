---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageHero from '../components/PageHero.astro';
import { courses, options } from '../data/courses';
import { site } from '../data/site';

const toneStyles: Record<string, string> = {
  dawn: 'radial-gradient(120% 120% at 80% -10%, rgba(243,184,58,.8), transparent 55%), linear-gradient(135deg,#E8821C,#BF5018)',
  gold: 'radial-gradient(120% 120% at 80% -10%, rgba(255,255,255,.5), transparent 50%), linear-gradient(135deg,#F3B83A,#E8821C)',
  lagoon: 'radial-gradient(120% 120% at 80% -10%, rgba(243,184,58,.55), transparent 55%), linear-gradient(135deg,#E8821C,#8a3d14)',
  shallow: 'radial-gradient(120% 120% at 80% -10%, rgba(255,255,255,.5), transparent 55%), linear-gradient(135deg,#ffce7a,#e9762f)',
  deep: 'radial-gradient(120% 120% at 80% 0%, rgba(243,184,58,.5), transparent 55%), linear-gradient(135deg,#bf5018,#5e2a0e)',
};
---

<Base title="コースのご案内" description="SUNRISE 久米島のマリン体験コース一覧。体験SUP・シュノーケル・はての浜ツアー・フィッシング・トレッキング・星空ツアーをご案内します。">
  <PageHero eyebrow="Courses" title="コースのご案内" watermark="遊" image="/images/courses/course-sup.jpg" alt="久米島でSUPを楽しむ様子" />
  <section class="pt-16">
    <div class="wrap max-w-3xl">
      <p class="text-[15px] leading-loose text-inksoft">久米島の海と自然を、いろいろな角度から楽しめる6つの体験プラン。気になるコースが見つかったら、お気軽にご相談ください。</p>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap space-y-16">
      {courses.map((course, i) => (
        <article id={course.slug} class="grid items-center gap-8 lg:grid-cols-2" data-reveal class:list={[i % 2 === 1 && 'lg:[&>div:first-child]:order-2']}>
          <div class="relative aspect-[16/11] w-full overflow-hidden rounded-2xl border border-line">
            {course.image
              ? <img src={course.image} alt={`${course.name}の様子`} class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
              : <div class="absolute inset-0" style={`background-image: ${toneStyles[course.duotone]}`}></div>}
            <div class="absolute inset-0" style="background:linear-gradient(0deg,rgba(34,22,12,.5),transparent 55%)"></div>
            <span class="absolute left-5 top-5 font-fraunces italic text-[12px] tracking-wide text-white/95 drop-shadow">{course.tag}</span>
            <p class="absolute bottom-5 left-5 right-5 font-mincho text-2xl text-white drop-shadow tracking-[0.06em]">{course.tagline}</p>
          </div>
          <div>
            <h2 class="font-mincho text-2xl font-normal text-ink sm:text-3xl">{course.name}</h2>
            <p class="mt-4 text-[15px] leading-loose text-ink/75">{course.detail}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {course.highlights.map((h) => (
                <span class="rounded-full bg-paper px-3.5 py-1.5 text-xs font-semibold text-ember">{h}</span>
              ))}
            </div>
            <a href={site.line} target="_blank" rel="noopener" class="btn-line mt-7">このコースを予約・相談</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- options -->
  <section class="bg-white py-20">
    <div class="wrap">
      <SectionHeading eyebrow="OPTIONS" title="追加オプション" />
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {options.map((opt) => (
          <div class="rounded-3xl border border-ink/10 bg-paper p-7">
            <h3 class="font-mincho text-lg font-normal text-ink">{opt.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">{opt.body}</p>
            {opt.note && <p class="mt-3 text-xs text-sun">{opt.note}</p>}
          </div>
        ))}
      </div>
      <p class="mt-8 text-xs text-ink/50">
        ※ 料金・所要時間・開催時期はシーズンや海況により変動します。詳細は予約時にご案内します。
      </p>
    </div>
  </section>
</Base>
