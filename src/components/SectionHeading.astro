---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
// タイトル内の「/」を改行可能ポイント(<wbr>)に変換する。
// break-keep（word-break: keep-all）と組み合わせることで、日本語見出しが
// 文節の途中で勝手に折り返さず、「/」を入れた位置でのみ改行されるようになる。
const titleHtml = title.replace(/\s*\/\s*/g, '<wbr>');
---
<div class:list={['max-w-2xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && (
    <p class:list={['kicker', align === 'center' && 'justify-center']}>
      <span class="bar"></span><span class="txt">{eyebrow}</span>
    </p>
  )}
  <h2 class="mt-4 h-display text-3xl sm:text-[40px] leading-tight break-keep [overflow-wrap:anywhere]" set:html={titleHtml}></h2>
</div>
