---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
---

<div class:list={['max-w-2xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && (
    <p class:list={['eyebrow', align === 'center' && 'justify-center']}>
      <span class="h-px w-6 bg-dawn"></span>{eyebrow}
    </p>
  )}
  <h2 class="mt-3 font-display text-3xl font-extrabold leading-tight tracking-tight text-abyss sm:text-4xl">
    {title}
  </h2>
</div>
