---
import { site, nav } from '../data/site';
---
<footer class="relative mt-24 overflow-hidden bg-ink text-paper">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px"
       style="background:linear-gradient(90deg,transparent,rgba(243,184,58,0.6),transparent)"></div>

  <div class="wrap grid gap-12 py-16 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <p class="font-mincho text-2xl tracking-wide2">久米島ツアー<span class="text-gold">SUNRISE</span></p>
      <p class="mt-4 max-w-sm text-sm leading-loose text-paper/70">
        沖縄・久米島の海を舞台に、<br class="hidden sm:block">心に残るマリン体験を。<br class="hidden sm:block">系列店 Cafe &amp; Bar SUNRISE もどうぞ。
      </p>
      <div class="mt-6 flex gap-3">
        <a href={site.line} target="_blank" rel="noopener" class="grid h-11 w-11 place-items-center rounded-full bg-white/10 text-paper transition-colors hover:bg-[#06C755] hover:text-white" aria-label="LINEで予約・相談">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M12 3C6.9 3 2.75 6.35 2.75 10.48c0 3.7 3.26 6.8 7.66 7.39.3.06.7.2.8.45.09.23.06.58.03.82l-.13.78c-.04.23-.18.9.8.49.98-.41 5.3-3.12 7.23-5.34h0c1.33-1.46 1.96-2.94 1.96-4.58C21.1 6.35 17.1 3 12 3zM8.13 12.68H6.36a.4.4 0 0 1-.39-.39V9.1a.39.39 0 1 1 .78 0v2.8h1.38a.39.39 0 1 1 0 .78zm1.53-.39a.39.39 0 1 1-.78 0V9.1a.39.39 0 1 1 .78 0v3.19zm3.78 0a.39.39 0 0 1-.7.24l-1.82-2.45v2.21a.39.39 0 1 1-.78 0V9.1a.39.39 0 0 1 .7-.24l1.82 2.45V9.1a.39.39 0 1 1 .78 0v3.19zm2.88-1.99a.39.39 0 1 1 0 .78h-1.38v.61h1.38a.39.39 0 1 1 0 .78h-1.77a.4.4 0 0 1-.39-.39V9.1a.4.4 0 0 1 .39-.39h1.77a.39.39 0 1 1 0 .78h-1.38v.61h1.38z"/></svg>
        </a>
        <a href={site.instagram} target="_blank" rel="noopener" class="grid h-11 w-11 place-items-center rounded-full bg-white/10 text-paper transition-colors hover:bg-sun hover:text-white" aria-label="Instagram">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.22.42.56.22.96.48 1.38.9.42.42.68.82.9 1.38.17.42.37 1.05.42 2.22.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.42 2.22-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.17-1.05.37-2.22.42-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.22-.42a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.17-.42-.37-1.05-.42-2.22C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.42-2.22.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.17 1.05-.37 2.22-.42C8.42 2.17 8.8 2.16 12 2.16zm0 1.62c-3.15 0-3.52.01-4.76.07-1.15.05-1.77.24-2.19.41-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.17.42-.36 1.04-.41 2.19-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.05 1.15.24 1.77.41 2.19.21.55.47.94.88 1.35.41.41.8.67 1.35.88.42.17 1.04.36 2.19.41 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c1.15-.05 1.77-.24 2.19-.41.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.17-.42.36-1.04.41-2.19.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.05-1.15-.24-1.77-.41-2.19a3.6 3.6 0 0 0-.88-1.35 3.6 3.6 0 0 0-1.35-.88c-.42-.17-1.04-.36-2.19-.41-1.24-.06-1.61-.07-4.76-.07zM12 6.87a5.13 5.13 0 1 0 0 10.26 5.13 5.13 0 0 0 0-10.26zm0 8.46a3.33 3.33 0 1 1 0-6.66 3.33 3.33 0 0 1 0 6.66zm6.54-8.66a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0z"/></svg>
        </a>
        <a href={site.tiktok} target="_blank" rel="noopener" class="grid h-11 w-11 place-items-center rounded-full bg-white/10 text-paper transition-colors hover:bg-gold hover:text-ink" aria-label="TikTok">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.05-2.82h-3.2v11.67a2.59 2.59 0 0 1-2.59 2.5 2.59 2.59 0 1 1 .81-5.05V6.85a5.77 5.77 0 0 0-.81-.06A5.78 5.78 0 1 0 15.56 12.57V8.9a7.44 7.44 0 0 0 4.34 1.39V7.09a4.28 4.28 0 0 1-3.3-1.27z"/></svg>
        </a>
      </div>
    </div>

    <nav aria-label="フッターメニュー">
      <p class="font-fraunces italic text-gold/80 text-sm">Menu</p>
      <ul class="mt-4 space-y-2.5 text-sm">
        {nav.map((item) => (
          <li><a href={item.href} class="text-paper/75 transition-colors hover:text-gold">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div>
      <p class="font-fraunces italic text-gold/80 text-sm">Contact</p>
      <ul class="mt-4 space-y-3 text-sm text-paper/75">
        <li>{site.address}</li>
        <li><a href={`tel:${site.tel}`} class="transition-colors hover:text-gold">TEL {site.tel}</a></li>
        <li><a href={`mailto:${site.email}`} class="break-all transition-colors hover:text-gold">{site.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="wrap flex flex-col items-center justify-between gap-4 py-6 text-xs text-paper/55 sm:flex-row">
      <p>© {new Date().getFullYear()} 久米島ツアーSUNRISE. All rights reserved.</p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href="/legal/tokushoho" class="transition-colors hover:text-gold">特定商取引法に基づく表記</a>
        <a href="/legal/privacy" class="transition-colors hover:text-gold">プライバシーポリシー</a>
        <a href="/legal/cookie" class="transition-colors hover:text-gold">Cookieポリシー</a>
      </div>
    </div>
  </div>
</footer>
