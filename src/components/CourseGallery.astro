---
interface Props {
  images: string[];
  alt?: string;
}
const { images, alt = '' } = Astro.props;
const imgs = (images && images.length ? images : []).slice(0, 8);
---
<div data-gallery>
  <figure class="relative aspect-[4/3] overflow-hidden rounded-3xl border border-line shadow-soft bg-cream">
    <!-- ぼかし背景で余白を自然に埋める（顔などが見切れないよう本体は contain 表示） -->
    <img data-main-bg src={imgs[0]} alt="" aria-hidden="true"
         class="absolute inset-0 h-full w-full scale-110 object-cover opacity-35 blur-2xl" />
    <img data-main src={imgs[0]} alt={alt} decoding="async"
         class="absolute inset-0 h-full w-full object-contain transition-opacity duration-200" />
  </figure>

  {imgs.length > 1 && (
    <div class="mt-3 grid grid-cols-4 gap-2 sm:gap-3">
      {imgs.map((src, i) => (
        <button
          type="button"
          data-thumb
          data-src={src}
          aria-label={`写真${i + 1}を表示`}
          class:list={[
            'aspect-square overflow-hidden rounded-xl border transition',
            i === 0 ? 'border-sun ring-2 ring-sun/40' : 'border-line opacity-70 hover:opacity-100',
          ]}
        >
          <img src={src.replace('.webp', '-t.webp')} alt="" class="h-full w-full object-cover" loading="lazy" decoding="async" />
        </button>
      ))}
    </div>
  )}
</div>

<script>
  document.querySelectorAll('[data-gallery]').forEach((g) => {
    const main = g.querySelector('[data-main]') as HTMLImageElement | null;
    const mainBg = g.querySelector('[data-main-bg]') as HTMLImageElement | null;
    const thumbs = g.querySelectorAll('[data-thumb]');
    if (!main) return;
    thumbs.forEach((t) => {
      t.addEventListener('click', () => {
        const src = t.getAttribute('data-src');
        if (!src) return;
        main.style.opacity = '0';
        setTimeout(() => {
          main.src = src;
          if (mainBg) mainBg.src = src;
          main.style.opacity = '1';
        }, 120);
        thumbs.forEach((x) => {
          x.classList.remove('border-sun', 'ring-2', 'ring-sun/40');
          x.classList.add('border-line', 'opacity-70');
        });
        t.classList.remove('border-line', 'opacity-70');
        t.classList.add('border-sun', 'ring-2', 'ring-sun/40');
      });
    });
  });
</script>
