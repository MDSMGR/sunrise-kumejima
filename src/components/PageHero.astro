---
interface Props {
  eyebrow?: string;
  title: string;
  watermark?: string;
  image: string;
  alt?: string;
}
const { eyebrow, title, watermark, image, alt = '' } = Astro.props;
---
<section class="fullbleed relative flex min-h-[52vh] items-end overflow-hidden text-white">
  <img src={image} alt={alt} class="absolute inset-0 h-full w-full object-cover" />
  <div class="absolute inset-0" style="background:linear-gradient(180deg,rgba(34,22,12,.28) 0%,rgba(34,22,12,.12) 40%,rgba(47,36,25,.72) 100%)"></div>
  {watermark && (
    <span class="watermark watermark-light right-4 top-1/2 -translate-y-1/2 text-[26vw] sm:right-12 sm:text-[180px]">{watermark}</span>
  )}
  <div class="relative z-10 mx-auto w-full max-w-content px-6 pb-12 pt-32 sm:px-8">
    {eyebrow && <p class="font-fraunces italic text-gold text-lg">{eyebrow}</p>}
    <h1 class="mt-2 h-hero text-[40px] sm:text-[58px]">{title}</h1>
  </div>
</section>
