---
import type { Course } from '../data/courses';
import PlanHeading from './PlanHeading.astro';
interface Props { course: Course; }
const { course } = Astro.props;

const tone: Record<Course['duotone'], string> = {
  dawn: 'radial-gradient(120% 120% at 80% -10%, rgba(243,184,58,.8), transparent 55%), linear-gradient(135deg,#E8821C,#BF5018)',
  gold: 'radial-gradient(120% 120% at 80% -10%, rgba(255,255,255,.5), transparent 50%), linear-gradient(135deg,#F3B83A,#E8821C)',
  lagoon: 'radial-gradient(120% 120% at 80% -10%, rgba(243,184,58,.55), transparent 55%), linear-gradient(135deg,#E8821C,#8a3d14)',
  shallow: 'radial-gradient(120% 120% at 80% -10%, rgba(255,255,255,.5), transparent 55%), linear-gradient(135deg,#ffce7a,#e9762f)',
  deep: 'radial-gradient(120% 120% at 80% 0%, rgba(243,184,58,.5), transparent 55%), linear-gradient(135deg,#bf5018,#5e2a0e)',
};
const pos = course.imagePos ?? 'center 40%';
---
{/* ===== モバイル：ツアー名をカードの外に（グループと統一） ===== */}
<a href={`/courses/${course.slug}`} class="group block sm:hidden">
  <PlanHeading tag={course.tag} name={course.name} tagline={course.tagline} popular={course.popular} />
  <div class="overflow-hidden rounded-2xl border border-line bg-card">
    <div class="relative h-52 overflow-hidden">
      {course.image
        ? <img src={course.image} alt={`${course.name}の様子`} class="h-full w-full object-cover" style={`object-position:${pos}`} loading="lazy" />
        : <div class="h-full w-full" style={`background-image:${tone[course.duotone]}`}></div>}
    </div>
    <div class="p-4">
      <p class="text-[14px] leading-relaxed text-inksoft">{course.summary}</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {course.highlights.map((h) => (
          <span class="rounded-full bg-paper px-3 py-1 text-xs text-ember font-medium">{h}</span>
        ))}
      </div>
      <div class="mt-4 flex items-center justify-between gap-3">
        {course.price
          ? <span class="font-mincho text-[15px] text-ink">{course.price}</span>
          : <span></span>}
        <span class="inline-flex flex-none items-center gap-1 font-fraunces italic text-sun text-sm whitespace-nowrap">詳しく見る →</span>
      </div>
    </div>
  </div>
</a>

{/* ===== デスクトップ：従来のカード（ツアー名はカード内） ===== */}
<a href={`/courses/${course.slug}`} class="group hidden sm:flex sm:flex-col overflow-hidden rounded-2xl bg-card border border-line transition-all duration-300 hover:-translate-y-1 hover:shadow-soft">
  <div class="px-6 pt-6">
    {course.popular && (
      <span class="inline-flex items-center gap-1 rounded-full bg-sun px-3 py-1 text-[11px] font-bold text-white shadow-soft">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.1 6.6.8-4.9 4.5 1.3 6.5L12 17.8 5.9 20.4l1.3-6.5L2.3 8.9l6.6-.8z"/></svg>
        一番人気
      </span>
    )}
    <h3 class:list={['font-mincho text-xl tracking-wide2 text-ink line-clamp-2', course.popular && 'mt-1.5']}>{course.name}</h3>
    <p class="mt-1 font-mincho text-sm text-ember">{course.tagline}</p>
  </div>
  <div class="relative mt-4 h-52 overflow-hidden">
    {course.image
      ? <img src={course.image} alt={`${course.name}の様子`} class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" style={`object-position:${pos}`} loading="lazy" />
      : <div class="absolute inset-0" style={`background-image:${tone[course.duotone]}`}></div>}
  </div>
  <div class="flex flex-1 flex-col p-6">
    <p class="text-[14px] leading-relaxed text-inksoft line-clamp-2">{course.summary}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {course.highlights.map((h) => (
        <span class="rounded-full bg-paper px-3 py-1 text-xs text-ember font-medium">{h}</span>
      ))}
    </div>
    <div class="mt-auto flex items-center justify-between gap-3 pt-4">
      {course.price
        ? <span class="font-mincho text-[15px] text-ink">{course.price}</span>
        : <span></span>}
      <span class="inline-flex flex-none items-center gap-1 font-fraunces italic text-sun text-sm whitespace-nowrap">詳しく見る →</span>
    </div>
  </div>
</a>
